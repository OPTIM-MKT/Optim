---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { getDictionary, type Locale, type PageKey } from "@/lib/site";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  pageKey: PageKey;
  snap?: boolean;
}

const { locale, title, description, snap = false } = Astro.props;
const dictionary = getDictionary(locale);
const seoTitle = title ?? dictionary.seo.defaultTitle;
const seoDescription = description ?? dictionary.seo.defaultDescription;
const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={seoDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === "en" ? "en_US" : "es_MX"} />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    <ClientRouter />
    <title>{seoTitle}</title>
  </head>
  <body>
    <Header locale={locale} dictionary={dictionary} currentPath={Astro.url.pathname} />
    <main
      data-lenis-prevent
      class:list={[
        snap
          ? "h-screen snap-y snap-mandatory overflow-y-scroll overscroll-y-none"
          : "min-h-[calc(100vh-5rem)] overflow-visible",
      ]}
    >
      <slot />
    </main>
    <Footer locale={locale} dictionary={dictionary} />
    <script>
      import Lenis from "lenis";

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

      if (!prefersReducedMotion.matches) {
        const lenis = new Lenis({
          lerp: 0.05,
          smoothWheel: true,
          syncTouch: false,
        });

        let frame = 0;

        const onFrame = (time: number) => {
          lenis.raf(time);
          frame = window.requestAnimationFrame(onFrame);
        };

        frame = window.requestAnimationFrame(onFrame);

        window.addEventListener(
          "pagehide",
          () => {
            window.cancelAnimationFrame(frame);
            lenis.destroy();
          },
          { once: true },
        );
      }
    </script>
  </body>
</html>

<style>
  html,
  body {
    width: 100%;
    height: 100%;
  }
</style>
