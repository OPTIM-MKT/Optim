---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Footer from "@/components/shared/Footer.astro";
import Header from "@/components/shared/Header.astro";
import ScrollToTop from "@/components/shared/ScrollToTop.astro";
import {
  DEFAULT_OG_IMAGE,
  getDictionary,
  localizePath,
  type Locale,
  type PageKey,
} from "@/lib/site";
import { SEO } from "astro-seo";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  pageKey: PageKey;
  snap?: boolean;
  hideHeader?: boolean;
  hideFooter?: boolean;
}

const { locale, title, description, snap = false, hideHeader = false, hideFooter = false } = Astro.props;
const dictionary = getDictionary(locale);
const seoTitle = title ?? dictionary.seo.defaultTitle;
const seoDescription = description ?? dictionary.seo.defaultDescription;
const canonicalUrl = Astro.url.href;
const currentPathWithoutLocale = Astro.url.pathname.startsWith("/en/")
  ? Astro.url.pathname.slice(4)
  : Astro.url.pathname === "/en"
    ? ""
    : Astro.url.pathname.slice(1);
const seoImage = new URL(DEFAULT_OG_IMAGE, Astro.url).href;
---

<!doctype html>
<html lang={locale}>
  <head>
    <script is:inline>
      const setDarkMode = () => {
        const storageKey = "optim-theme";
        const storedTheme = window.localStorage.getItem(storageKey);
        const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = storedTheme ?? (systemDark ? "dark" : "light");
        document.documentElement.classList.toggle("dark", theme === "dark");
        document.documentElement.dataset.theme = theme;
      };
      setDarkMode();
      document.addEventListener("astro:after-swap", setDarkMode);
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO
      title={seoTitle}
      description={seoDescription}
      canonical={canonicalUrl}
      languageAlternates={[
        {
          href: new URL(localizePath("es", currentPathWithoutLocale), Astro.url).href,
          hrefLang: "es",
        },
        {
          href: new URL(localizePath("en", currentPathWithoutLocale), Astro.url).href,
          hrefLang: "en",
        },
      ]}
      openGraph={{
        basic: {
          title: seoTitle,
          type: "website",
          image: seoImage,
          url: canonicalUrl,
        },
        optional: {
          description: seoDescription,
          locale: locale === "en" ? "en_US" : "es_MX",
          localeAlternate: [locale === "en" ? "es_MX" : "en_US"],
          siteName: "Optim",
        },
        image: {
          alt: seoTitle,
          width: 1200,
          height: 630,
          type: "image/svg+xml",
        },
      }}
      twitter={{
        card: "summary_large_image",
        title: seoTitle,
        description: seoDescription,
        image: seoImage,
        imageAlt: seoTitle,
      }}
      extend={{
        link: [{ rel: "icon", type: "image/svg+xml", href: "/favicon.svg" }],
        meta: [{ name: "generator", content: Astro.generator }],
      }}
    />
    <ClientRouter />
    <title>{seoTitle}</title>
  </head>
  <body>
    {!hideHeader && (
      <Header
        locale={locale}
        dictionary={dictionary}
        currentPath={Astro.url.pathname}
      />
    )}
    <main class="min-h-[calc(100vh-5rem)]">
      <slot />
    </main>
    {!hideFooter && <Footer locale={locale} dictionary={dictionary} />}
    <ScrollToTop />
    <script>
      import Lenis from "lenis";

      let lenis: Lenis | null = null;
      let frame = 0;

      const initLenis = () => {
        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        );
        if (prefersReducedMotion.matches) return;

        if (lenis) {
          lenis.destroy();
          window.cancelAnimationFrame(frame);
        }

        lenis = new Lenis({
          lerp: 0.05,
          smoothWheel: true,
          syncTouch: false,
        });

        const onFrame = (time: number) => {
          lenis?.raf(time);
          frame = window.requestAnimationFrame(onFrame);
        };

        frame = window.requestAnimationFrame(onFrame);
      };

      document.addEventListener("astro:page-load", initLenis);

      document.addEventListener("astro:before-swap", () => {
        if (lenis) {
          lenis.destroy();
          window.cancelAnimationFrame(frame);
          lenis = null;
        }
      });

      const storageKey = "optim-theme";
      const updateThemeUi = (theme: string) => {
        document.querySelectorAll("[data-theme-label]").forEach((label) => {
          label.textContent = theme === "dark" ? "Light" : "Dark";
        });
      };

      const applyTheme = (theme: string) => {
        document.documentElement.classList.toggle("dark", theme === "dark");
        document.documentElement.dataset.theme = theme;
        window.localStorage.setItem(storageKey, theme);
        updateThemeUi(theme);
      };

      document.addEventListener("astro:page-load", () => {
        updateThemeUi(document.documentElement.dataset.theme ?? "light");
      });

      // The module script runs once per session, which is fine for document listeners
      document.addEventListener("click", (event) => {
        const toggle = event.target instanceof Element
          ? event.target.closest("[data-theme-toggle]")
          : null;

        if (!toggle) {
          return;
        }

        const nextTheme =
          document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        applyTheme(nextTheme);
      });
    </script>
  </body>
</html>

<style>
  html,
  body {
    width: 100%;
    height: 100%;
  }
</style>
