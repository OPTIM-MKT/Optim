---
import Layout from "@/layouts/Layout.astro";
import StorySection from "@/components/about/StorySection.astro";
import PrinciplesSection from "@/components/about/PrinciplesSection.astro";
import TeamSection from "@/components/about/TeamSection.astro";
import PageHero from "@/components/shared/PageHero.astro";
import { getDictionary, type Locale } from "@/lib/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const teamMembers = [
  {
    id: "ceo",
    name: "Leonel Garza",
    role: locale === "es" ? "Direccion Estrategica" : "Strategic Direction",
    image: "/images/placeholders/team-1.svg",
    email: "leonel@optim.mx",
    socials: [
      { label: "LinkedIn", href: "https://linkedin.com/company/optim" },
      { label: "Instagram", href: "https://instagram.com/optim" },
    ],
  },
  {
    id: "creative",
    name: locale === "es" ? "Sofia Torres" : "Sofia Torres",
    role: locale === "es" ? "Direccion Creativa" : "Creative Direction",
    image: "/images/placeholders/team-2.svg",
    email: "sofia@optim.mx",
    socials: [
      { label: "Behance", href: "https://behance.net/optim" },
      { label: "Instagram", href: "https://instagram.com/optim" },
    ],
  },
  {
    id: "performance",
    name: "Marco Ruiz",
    role: locale === "es" ? "Performance y Data" : "Performance and Data",
    image: "/images/placeholders/team-3.svg",
    email: "marco@optim.mx",
    socials: [
      { label: "LinkedIn", href: "https://linkedin.com/company/optim" },
      { label: "Email", href: "mailto:marco@optim.mx" },
    ],
  },
  {
    id: "ops",
    name: "Valeria Nunez",
    role: locale === "es" ? "Automatizacion y CRM" : "Automation and CRM",
    image: "/images/placeholders/team-4.svg",
    email: "valeria@optim.mx",
    socials: [
      { label: "LinkedIn", href: "https://linkedin.com/company/optim" },
      { label: "WhatsApp", href: "https://wa.me/528187654321" },
    ],
  },
];
---

<Layout
  locale={locale}
  title={dictionary.seo.pages.about.title}
  description={dictionary.seo.pages.about.description}
  pageKey="about"
>
  <PageHero
    eyebrow={dictionary.aboutPage.hero.eyebrow}
    title={dictionary.aboutPage.hero.title}
    description={dictionary.aboutPage.hero.description}
  />
  <StorySection dictionary={dictionary} />
  <TeamSection
    members={teamMembers}
    eyebrow={locale === "es" ? "Equipo" : "Team"}
    title={locale === "es" ? "Equipo Optim" : "Optim Team"}
  />
  <PrinciplesSection dictionary={dictionary} />
</Layout>
