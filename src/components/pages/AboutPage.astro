---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/PageHero.astro";
import { getDictionary, type Locale } from "@/lib/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
---

<Layout
  locale={locale}
  title={dictionary.seo.pages.about.title}
  description={dictionary.seo.pages.about.description}
  pageKey="about"
>
  <PageHero
    eyebrow={dictionary.aboutPage.hero.eyebrow}
    title={dictionary.aboutPage.hero.title}
    description={dictionary.aboutPage.hero.description}
  />

  <section class="py-20">
    <div class="section-shell grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <article class="glass-panel rounded-[2rem] border border-line p-8 md:p-10">
        <p class="editorial-label">{dictionary.aboutPage.story.title}</p>
        <p class="mt-8 text-3xl font-semibold leading-tight text-ink md:text-4xl">
          {dictionary.aboutPage.story.description}
        </p>
      </article>
      <article class="rounded-[2rem] border border-line bg-ink p-8 text-canvas md:p-10">
        <p class="editorial-label !text-canvas/60">{dictionary.aboutPage.branchesTitle}</p>
        <p class="mt-8 text-xl leading-8 text-canvas/76">{dictionary.aboutPage.teamNote}</p>
      </article>
    </div>
  </section>

  <section class="pb-24">
    <div class="section-shell">
      <h2 class="text-4xl font-semibold text-ink md:text-6xl">{dictionary.aboutPage.principles.title}</h2>
      <div class="mt-12 grid gap-4 md:grid-cols-3">
        {
          dictionary.aboutPage.principles.items.map((item) => (
            <article class="rounded-[1.75rem] border border-line bg-canvas/75 p-6">
              <p class="text-2xl font-semibold text-ink">{item.title}</p>
              <p class="mt-4 text-base leading-7">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
