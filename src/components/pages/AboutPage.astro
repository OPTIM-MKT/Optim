---
import Layout from "@/layouts/Layout.astro";
import StorySection from "@/components/about/StorySection.astro";
import PrinciplesSection from "@/components/about/PrinciplesSection.astro";
import TeamSection from "@/components/about/TeamSection.astro";
import PageHero from "@/components/shared/PageHero.astro";
import { getDictionary, type Locale } from "@/lib/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const teamMembers = [
  {
    id: "ceo",
    name: "César Lozano",
    role: locale === "es" ? "CEO" : "CEO",
    image: "/images/placeholders/team-1.svg",
    email: "cesarlozano@optimmkt.com",
    socials: [
      {
        label: "LinkedIn",
        href: "https://www.linkedin.com/in/c%C3%A9sar-lozano-a097911b5/",
      },
    ],
  },
  {
    id: "project-manager",
    name: "Marcelo Figueroa",
    role: locale === "es" ? "Project Manager" : "Project Manager",
    image: "/images/placeholders/team-2.svg",
  },
  {
    id: "design-director",
    name: "Sandra Sandoval",
    role: "Directora de Diseño",
    image: "/images/placeholders/team-3.svg",
  },
  {
    id: "ops",
    name: "Raúl Garza",
    role: locale === "es" ? "Director de Edición" : "Editor Director",
    image: "/images/placeholders/team-4.svg",
  },
  {
    id: "web-development-lead",
    name: "Leonel Elizarraraz",
    role: locale === "es" ? "Líder de Desarrollo Web" : "Web Development Lead",
    image: "/images/placeholders/team-1.svg",
  },
  {
    id: "strategic-advisor",
    name: "Carlos Urrutia",
    role: locale === "es" ? "Asesor Estratégico" : "Strategic Advisor",
    image: "/images/placeholders/team-2.svg",
  },
];
---

<Layout
  locale={locale}
  title={dictionary.seo.pages.about.title}
  description={dictionary.seo.pages.about.description}
  pageKey="about"
>
  <PageHero
    eyebrow={dictionary.aboutPage.hero.eyebrow}
    title={dictionary.aboutPage.hero.title}
    description={dictionary.aboutPage.hero.description}
    isPrimary={true}
    isLogo={true}
  />
  <StorySection dictionary={dictionary} />
  <TeamSection
    members={teamMembers}
    eyebrow={locale === "es" ? "Equipo" : "Team"}
    title={locale === "es" ? "Equipo Optim" : "Optim Team"}
  />
  <PrinciplesSection dictionary={dictionary} />
</Layout>
