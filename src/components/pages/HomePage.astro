---
import { getCollection } from "astro:content";

import SwiperCarousel, {
  type BannerSlide,
  type HeroSlide,
} from "@/components/SwiperCarousel";
import Layout from "@/layouts/Layout.astro";
import { getDictionary, localizePath, type Locale } from "@/lib/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const empresas = await getCollection("empresas");

const heroSlides: HeroSlide[] = dictionary.home.hero.slides.map((slide, index) => ({
  id: `hero-${index + 1}`,
  eyebrow: slide.eyebrow,
  title: slide.title,
  description: slide.description,
  ctaLabel: dictionary.home.hero.ctaPrimary,
  ctaHref: localizePath(locale, "contact"),
  metrics: index === 0 ? dictionary.home.hero.stats : undefined,
}));

const companySlides: BannerSlide[] = empresas.map((empresa) => ({
  id: empresa.id,
  name: empresa.data.name,
  industry: empresa.data.industry,
  description: empresa.data.results ?? empresa.data.description,
  image: empresa.data.image,
}));
---

<Layout
  locale={locale}
  title={dictionary.seo.pages.home.title}
  description={dictionary.seo.pages.home.description}
  pageKey="home"
  snap
>
  <SwiperCarousel
    client:load
    variant="hero"
    items={heroSlides}
    ariaLabel={dictionary.home.hero.kicker}
  />

  <section class="snap-section flex items-center">
    <div class="section-shell grid gap-10 py-20 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-end">
      <div class="space-y-6">
        <p class="editorial-label eyebrow-rule">{dictionary.home.pillars.eyebrow}</p>
        <h1 class="max-w-4xl text-5xl font-semibold text-ink md:text-7xl lg:text-[7rem]">
          {dictionary.home.hero.headline}
          <span class="block text-strategic">{dictionary.home.hero.headlineAccent}</span>
        </h1>
      </div>

      <div class="space-y-6">
        <p class="max-w-2xl text-lg leading-8">{dictionary.home.hero.subheadline}</p>
        <div class="flex flex-wrap gap-4">
          <a
            href={localizePath(locale, "contact")}
            class="rounded-full bg-ink px-6 py-3 text-sm font-semibold text-canvas transition-transform duration-300 hover:-translate-y-0.5"
          >
            {dictionary.home.hero.ctaPrimary}
          </a>
          <a
            href={localizePath(locale, "services")}
            class="rounded-full border border-line px-6 py-3 text-sm font-semibold text-ink transition-colors duration-300 hover:bg-panel"
          >
            {dictionary.home.hero.ctaSecondary}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="snap-section flex items-center">
    <div class="section-shell py-20">
      <div class="max-w-3xl">
        <p class="editorial-label eyebrow-rule">{dictionary.home.pillars.eyebrow}</p>
        <h2 class="mt-6 text-4xl font-semibold text-ink md:text-6xl">{dictionary.home.pillars.title}</h2>
        <p class="mt-6 text-lg leading-8">{dictionary.home.pillars.description}</p>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {
          dictionary.home.pillars.items.map((pillar) => (
            <article class="glass-panel rounded-[2rem] border border-line p-8 md:p-10">
              <p class="editorial-label">{pillar.title}</p>
              <p class="mt-8 text-3xl font-semibold leading-tight text-ink md:text-4xl">
                {pillar.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="snap-section flex items-center">
    <div class="section-shell py-20">
      <div class="max-w-3xl">
        <p class="editorial-label eyebrow-rule">{dictionary.home.servicesPreview.eyebrow}</p>
        <h2 class="mt-6 text-4xl font-semibold text-ink md:text-6xl">
          {dictionary.home.servicesPreview.title}
        </h2>
      </div>
      <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {
          dictionary.home.servicesPreview.items.map((service) => (
            <article class="rounded-[1.75rem] border border-line bg-canvas/70 p-6 transition-transform duration-300 hover:-translate-y-1 hover:border-strategic">
              <p class="text-2xl font-semibold text-ink">{service}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="snap-section flex items-center">
    <div class="section-shell py-20">
      <div class="max-w-3xl">
        <p class="editorial-label eyebrow-rule">{dictionary.home.process.eyebrow}</p>
        <h2 class="mt-6 text-4xl font-semibold text-ink md:text-6xl">{dictionary.home.process.title}</h2>
      </div>
      <div class="mt-12 grid gap-4 md:grid-cols-5">
        {
          dictionary.home.process.steps.map((step, index) => (
            <article class="glass-panel rounded-[1.75rem] border border-line p-6">
              <p class="text-sm font-semibold uppercase tracking-[0.22em] text-strategic">0{index + 1}</p>
              <h3 class="mt-8 text-2xl font-semibold text-ink">{step.title}</h3>
              <p class="mt-4 text-sm leading-7">{step.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {
    companySlides.length > 0 ? (
      <SwiperCarousel
        client:visible
        variant="banner"
        items={companySlides}
        ariaLabel={dictionary.home.companies.title}
      />
    ) : (
      <section class="snap-section flex items-center">
        <div class="section-shell py-20">
          <p class="editorial-label eyebrow-rule">{dictionary.home.companies.eyebrow}</p>
          <h2 class="mt-6 max-w-3xl text-4xl font-semibold text-ink md:text-6xl">
            {dictionary.home.companies.title}
          </h2>
          <p class="mt-6 max-w-2xl text-lg leading-8">{dictionary.home.companies.description}</p>
        </div>
      </section>
    )
  }

  <section class="snap-section flex items-center">
    <div class="section-shell py-20">
      <div class="max-w-3xl">
        <p class="editorial-label eyebrow-rule">{dictionary.home.branches.eyebrow}</p>
        <h2 class="mt-6 text-4xl font-semibold text-ink md:text-6xl">{dictionary.home.branches.title}</h2>
      </div>
      <div class="mt-12 grid gap-4 lg:grid-cols-2">
        {
          dictionary.home.branches.items.map((branch) => (
            <article class="rounded-[2rem] border border-line bg-ink px-8 py-10 text-canvas">
              <p class="text-3xl font-semibold md:text-4xl">{branch.name}</p>
              <p class="mt-6 max-w-2xl text-base leading-7 text-canvas/72">{branch.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="snap-section flex items-center">
    <div class="section-shell py-20">
      <article class="glass-panel overflow-hidden rounded-[2.5rem] border border-line">
        <div class="grid gap-8 p-8 md:p-12 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
          <div>
            <p class="editorial-label eyebrow-rule">{dictionary.navigation.contact}</p>
            <h2 class="mt-6 max-w-4xl text-4xl font-semibold text-ink md:text-6xl">
              {dictionary.home.closing.title}
            </h2>
            <p class="mt-6 max-w-2xl text-lg leading-8">{dictionary.home.closing.description}</p>
          </div>

          <a
            href={localizePath(locale, "contact")}
            class="inline-flex h-fit rounded-full bg-strategic px-8 py-4 text-sm font-semibold uppercase tracking-[0.2em] text-canvas transition-transform duration-300 hover:-translate-y-0.5"
          >
            {dictionary.home.closing.cta}
          </a>
        </div>
      </article>
    </div>
  </section>
</Layout>
