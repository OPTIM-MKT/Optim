---
import { getCollection } from "astro:content";
import { type BannerSlide, type HeroSlide } from "@/components/SwiperCarousel";
import HomeBranchesSection from "@/components/home/HomeBranchesSection.astro";
import HomeClosingSection from "@/components/home/HomeClosingSection.astro";
import HomeCompaniesSection from "@/components/home/HomeCompaniesSection.astro";
import HomeHeroSection from "@/components/home/HomeHeroSection.astro";
import HomePillarsSection from "@/components/home/HomePillarsSection.astro";
import HomeProcessSection from "@/components/home/HomeProcessSection.astro";
import HomeServicesPreviewSection from "@/components/home/HomeServicesPreviewSection.astro";
import HomeTestimonialsSection from "@/components/home/HomeTestimonialsSection.astro";
import ParallaxMedia from "@/components/shared/ParallaxMedia.astro";
import ImageTextSection from "@/components/shared/ImageTextSection.astro";

import Layout from "@/layouts/Layout.astro";
import { DEFAULT_MEDIA_IMAGE, getDictionary, localizePath, type Locale } from "@/lib/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const empresas = (await getCollection("empresas")).sort(
  (left, right) => left.data.order - right.data.order,
);
const heroBackgrounds = [
  "https://images.unsplash.com/photo-1551434678-e076c223a692?q=80&w=2850&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2850&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?q=80&w=2850&auto=format&fit=crop",
];

const heroSlides: HeroSlide[] = dictionary.home.hero.slides.map(
  (slide, index) => ({
    id: `hero-${index + 1}`,
    eyebrow: slide.eyebrow,
    title: slide.title,
    description: slide.description,
    ctaLabel: dictionary.home.hero.ctaPrimary,
    ctaHref: localizePath(locale, "contact"),
    backgroundImage: heroBackgrounds[index] ?? DEFAULT_MEDIA_IMAGE,
    metrics: index === 0 ? dictionary.home.hero.stats : undefined,
  }),
);

const companySlides: BannerSlide[] = empresas.map((empresa) => ({
  id: empresa.id,
  name: empresa.data.name,
  industry: empresa.data.industry,
  description: empresa.data.results ?? empresa.data.description,
  image: empresa.data.logoUrl ?? empresa.data.featuredImage ?? DEFAULT_MEDIA_IMAGE,
}));
---

<Layout
  locale={locale}
  title={dictionary.seo.pages.home.title}
  description={dictionary.seo.pages.home.description}
  pageKey="home"
  snap
>
  <HomeHeroSection slides={heroSlides} ariaLabel={dictionary.home.hero.kicker} />
  <HomeServicesPreviewSection dictionary={dictionary} locale={locale} />
  <ImageTextSection />
  <HomePillarsSection dictionary={dictionary} />
  <ParallaxMedia
    eyebrow={dictionary.home.companies.eyebrow}
    title={dictionary.home.companies.title}
    description={dictionary.home.companies.description}
    topImage="/images/placeholders/parallax-top.svg"
    bottomImage="/images/placeholders/parallax-bottom.svg"
  />
  <HomeProcessSection dictionary={dictionary} />
  <HomeCompaniesSection slides={companySlides} dictionary={dictionary} />
  <HomeTestimonialsSection />
  <HomeBranchesSection dictionary={dictionary} />
  <HomeClosingSection dictionary={dictionary} locale={locale} />
</Layout>
