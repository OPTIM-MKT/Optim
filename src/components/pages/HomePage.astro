---
import { type HeroSlide } from "@/components/SwiperCarousel";
import BranchesSection from "@/components/home/BranchesSection.astro";
import ClosingSection from "@/components/home/ClosingSection.astro";
import HeroSection from "@/components/home/HeroSection.astro";
import PillarsSection from "@/components/home/PillarsSection.astro";
import ProcessSection from "@/components/home/ProcessSection.astro";
import ServicesPreviewSection from "@/components/home/ServicesPreviewSection.astro";
import TestimonialsSection from "@/components/home/TestimonialsSection.astro";
import ParallaxMedia from "@/components/shared/ParallaxMedia.astro";
import Layout from "@/layouts/Layout.astro";

import {
  DEFAULT_MEDIA_IMAGE,
  getDictionary,
  localizePath,
  type Locale,
} from "@/lib/site";
import WorksSlider from "../home/WorksSlider";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const heroBackgrounds = [
  "https://images.unsplash.com/photo-1551434678-e076c223a692?q=80&w=2850&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2850&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?q=80&w=2850&auto=format&fit=crop",
];

const heroSlides: HeroSlide[] = dictionary.home.hero.slides.map(
  (slide, index) => ({
    id: `hero-${index + 1}`,
    eyebrow: slide.eyebrow,
    title: slide.title,
    description: slide.description,
    ctaLabel: dictionary.home.hero.ctaPrimary,
    ctaHref: localizePath(locale, "contact"),
    backgroundImage: heroBackgrounds[index] ?? DEFAULT_MEDIA_IMAGE,
    metrics: index === 0 ? dictionary.home.hero.stats : undefined,
  }),
);
---

<Layout
  locale={locale}
  title={dictionary.seo.pages.home.title}
  description={dictionary.seo.pages.home.description}
  pageKey="home"
  snap
  stickyHeader
>
  <HeroSection slides={heroSlides} ariaLabel={dictionary.home.hero.kicker} />
  <ServicesPreviewSection dictionary={dictionary} locale={locale} />
  <WorksSlider
    client:visible
    headText={dictionary.home.worksSlider.headline}
    title={dictionary.home.worksSlider.title}
  />

  {/* Shared parallax wrapper — Pillars + ParallaxMedia + Process */}
  <div class="pillars-process-wrapper relative overflow-hidden">
    {/* Parallax background layer */}
    <div
      class="pointer-events-none absolute inset-0 bg-cover bg-center bg-fixed"
      style="background-image: url('https://images.unsplash.com/photo-1504384308090-c894fdcc538d?q=80&w=2940&auto=format&fit=crop');"
      aria-hidden="true"
    >
    </div>
    {/* Dark overlay */}
    <div
      class="pointer-events-none absolute inset-0 bg-black/50"
      aria-hidden="true"
    >
    </div>

    {/* Content sits above the background */}
    <div class="relative z-10">
      <PillarsSection dictionary={dictionary} />
      <ParallaxMedia
        eyebrow={dictionary.home.companies.eyebrow}
        title={dictionary.home.companies.title}
        description={dictionary.home.companies.description}
        topImage="https://images.unsplash.com/photo-1444222362538-bfeab10e1282?q=80&w=3132&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
        bottomImage="https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2850&auto=format&fit=crop"
      />
      <ProcessSection dictionary={dictionary} />
    </div>
  </div>
  <TestimonialsSection dictionary={dictionary} />
  <BranchesSection dictionary={dictionary} locale={locale} />
  <ClosingSection dictionary={dictionary} locale={locale} />
</Layout>
