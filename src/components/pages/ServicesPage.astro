---
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/shared/PageHero.astro";
import CaseStudiesSection from "@/components/services/CaseStudiesSection.astro";
import ServicesGridSection from "@/components/services/ServicesGridSection.astro";
import ServicesMethodSection from "@/components/services/ServicesMethodSection.astro";
import WorksSlider from "../home/WorksSlider";

import { getDictionary, type Locale } from "@/lib/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const empresas = (await getCollection("empresas"))
  .filter((empresa) => empresa.id.startsWith(`${locale}/`))
  .sort((left, right) => left.data.order - right.data.order);
---

<Layout
  locale={locale}
  title={dictionary.seo.pages.services.title}
  description={dictionary.seo.pages.services.description}
  pageKey="services"
>
  <PageHero
    eyebrow={dictionary.servicesPage.hero.eyebrow}
    title={dictionary.servicesPage.hero.title}
    description={dictionary.servicesPage.hero.description}
    isPrimary={true}
    isLogo={true}
  />
  <ServicesGridSection dictionary={dictionary} locale={locale} />
  <WorksSlider
    client:visible
    headText={dictionary.home.worksSlider.headline}
    title={dictionary.home.worksSlider.title}
  />
  <CaseStudiesSection dictionary={dictionary} empresas={empresas} />
  <ServicesMethodSection dictionary={dictionary} locale={locale} />
</Layout>
