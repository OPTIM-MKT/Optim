---
import { DEFAULT_MEDIA_IMAGE } from "@/lib/site";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  topImage?: string;
  bottomImage?: string;
}

const {
  eyebrow,
  title,
  description,
  topImage = DEFAULT_MEDIA_IMAGE,
  bottomImage = DEFAULT_MEDIA_IMAGE,
} = Astro.props;
---

<main class="bg-white py-20 dark:bg-black/80">
  <section class="section-shell py-20">
    <article
      class="media-frame relative overflow-hidden px-6 py-24 md:px-10"
      data-parallax-root
    >
      <img
        src={topImage}
        alt={title}
        class="pointer-events-none absolute -right-10 top-0 h-40 w-40 rounded-[2rem] object-cover md:h-64 md:w-64"
        data-parallax-layer="top"
      />
      <img
        src={bottomImage}
        alt={title}
        class="pointer-events-none absolute -left-8 bottom-0 h-36 w-36 rounded-[2rem] object-cover md:h-56 md:w-56"
        data-parallax-layer="bottom"
      />

      <div class="relative mx-auto max-w-4xl text-center">
        <p class="editorial-label">{eyebrow}</p>
        <h2 class="mt-6 text-4xl font-semibold text-ink md:text-6xl">
          {title}
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8">{description}</p>
      </div>
    </article>

    <script>
      const roots = document.querySelectorAll("[data-parallax-root]");

      const updateParallax = () => {
        roots.forEach((root) => {
          const rect = root.getBoundingClientRect();
          const viewportHeight = window.innerHeight;
          const progress =
            (viewportHeight - rect.top) / (viewportHeight + rect.height);

          root.querySelectorAll("[data-parallax-layer]").forEach((layer) => {
            const isTop = layer.getAttribute("data-parallax-layer") === "top";
            const distance = (progress - 0.5) * (isTop ? 70 : -70);
            if (layer instanceof HTMLElement) {
              layer.style.transform = `translate3d(0, ${distance}px, 0)`;
            }
          });
        });
      };

      updateParallax();
      window.addEventListener("scroll", updateParallax, { passive: true });
    </script>
  </section>
</main>
