---
import { Image } from "astro:assets";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  /** @deprecated — replaced by floating icon cluster. Kept for API compat. */
  topImage?: string;
  /** @deprecated — replaced by floating icon cluster. Kept for API compat. */
  bottomImage?: string;
}

const { eyebrow, title, description } = Astro.props;

import one from "@/assets/icons/one.webp";
import two from "@/assets/icons/two.webp";
import tre from "@/assets/icons/tre.webp";
import punta from "@/assets/icons/punta.webp";
import qrush from "@/assets/icons/qrush.webp";
import optim from "@/assets/images/icon.webp";

// ── Floating client logos
// Three icons per cluster arranged as: 1 on top, 2 on bottom
// Replace src with real client logos when available.
const clusterA = [
  { id: "ca-1", src: one, alt: "Cliente A1" },
  { id: "ca-2", src: two, alt: "Cliente A2" },
  { id: "ca-3", src: tre, alt: "Cliente A3" },
];

const clusterB = [
  { id: "cb-1", src: punta, alt: "Cliente B1" },
  { id: "cb-2", src: qrush, alt: "Cliente B2" },
  { id: "cb-3", src: optim, alt: "Cliente B3" },
];
---

<main
  class="py-20 bg-white/80 backdrop-blur-sm dark:bg-black/60 overflow-hidden"
>
  <section class="section-shell py-20">
    <article
      class="media-frame relative overflow-hidden px-6 py-24 md:px-10"
      data-parallax-root
    >
      <!-- ── Cluster A — top-right: 1 icon above, 2 below ───────────────── -->
      <div
        class="parallax-cluster-wrap absolute -top-4 -right-4 md:top-0 md:right-0"
        data-parallax-layer="top"
        aria-label="Clientes — grupo A"
      >
        <!-- Row 1: single centered icon -->
        <div class="parallax-cluster-row parallax-cluster-row--single">
          <a
            href="#testimonios"
            class="parallax-icon-btn"
            aria-label={`Ver testimonio de ${clusterA[0].alt}`}
            title={`Ver testimonio — ${clusterA[0].alt}`}
          >
            <Image
              src={clusterA[0].src}
              alt={clusterA[0].alt}
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>
        <!-- Row 2: two icons side by side -->
        <div class="parallax-cluster-row">
          {
            clusterA.slice(1).map((icon) => (
              <a
                href="#testimonios"
                class="parallax-icon-btn"
                aria-label={`Ver testimonio de ${icon.alt}`}
                title={`Ver testimonio — ${icon.alt}`}
              >
                <Image
                  src={icon.src}
                  alt={icon.alt}
                  loading="lazy"
                  decoding="async"
                />
              </a>
            ))
          }
        </div>
      </div>

      <!-- ── Cluster B — bottom-left: 1 icon above, 2 below ─────────────── -->
      <div
        class="parallax-cluster-wrap absolute -bottom-4 -left-4 md:bottom-0 md:left-0"
        data-parallax-layer="bottom"
        aria-label="Clientes — grupo B"
      >
        <!-- Row 1: single centered icon -->
        <div class="parallax-cluster-row parallax-cluster-row--single">
          <a
            href="#testimonios"
            class="parallax-icon-btn"
            aria-label={`Ver testimonio de ${clusterB[0].alt}`}
            title={`Ver testimonio — ${clusterB[0].alt}`}
          >
            <Image
              src={clusterB[0].src}
              alt={clusterB[0].alt}
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>
        <!-- Row 2: two icons side by side -->
        <div class="parallax-cluster-row">
          {
            clusterB.slice(1).map((icon) => (
              <a
                href="#testimonios"
                class="parallax-icon-btn"
                aria-label={`Ver testimonio de ${icon.alt}`}
                title={`Ver testimonio — ${icon.alt}`}
              >
                <Image
                  src={icon.src}
                  alt={icon.alt}
                  loading="lazy"
                  decoding="async"
                />
              </a>
            ))
          }
        </div>
      </div>

      <!-- ── Central content ─────────────────────────────────────────────── -->
      <div class="relative mx-auto max-w-4xl text-center">
        <p class="editorial-label">{eyebrow}</p>
        <h2 class="mt-6 text-4xl font-semibold text-ink md:text-6xl">
          {title}
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8">{description}</p>
      </div>
    </article>

    <script>
      const roots = document.querySelectorAll("[data-parallax-root]");

      const updateParallax = () => {
        roots.forEach((root) => {
          const rect = root.getBoundingClientRect();
          const viewportHeight = window.innerHeight;
          const progress =
            (viewportHeight - rect.top) / (viewportHeight + rect.height);

          root.querySelectorAll("[data-parallax-layer]").forEach((layer) => {
            const isTop = layer.getAttribute("data-parallax-layer") === "top";
            const distance = (progress - 0.5) * (isTop ? 60 : -60);
            if (layer instanceof HTMLElement) {
              layer.style.transform = `translate3d(0, ${distance}px, 0)`;
            }
          });
        });
      };

      updateParallax();
      window.addEventListener("scroll", updateParallax, { passive: true });
    </script>
  </section>
</main>
