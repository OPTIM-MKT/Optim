---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  isPrimary?: boolean;
  isLogo?: boolean;
}

const {
  eyebrow,
  title,
  description,
  isPrimary = false,
  isLogo = false,
} = Astro.props;

import Logo from "@/assets/images/logo.webp";
import { Image } from "astro:assets";

const titleWords = title.trim().split(" ");
const lastWord = titleWords.length > 1 ? titleWords.pop() : "";
const restOfTitle = titleWords.join(" ");
---

<section class="flex items-center">
  <div class="section-shell py-24 w-full">
    <div
      class={isLogo
        ? "grid grid-cols-1 lg:grid-cols-[1.2fr_0.8fr] gap-12 lg:gap-20 items-center"
        : ""}
    >
      <div class={isLogo ? "max-w-3xl" : "max-w-5xl"}>
        <p class="editorial-label eyebrow-rule">{eyebrow}</p>
        <h1
          class="mt-6 text-5xl font-semibold text-ink lg:text-7xl text-balance leading-[1.1]"
        >
          {isPrimary && lastWord ? restOfTitle : title}
          {
            isPrimary && lastWord && (
              <span class="text-strategic"> {lastWord}</span>
            )
          }
        </h1>
        <p
          class="mt-8 max-w-3xl text-lg leading-relaxed text-muted md:text-xl text-balance"
        >
          {description}
        </p>
      </div>

      {
        isLogo && (
          <div class="flex justify-center w-full mt-10 lg:mt-0">
            <div class="relative w-full max-w-60 aspect-square border border-ink rounded-[2.5rem] bg-white/40 dark:bg-gray-900/40 backdrop-blur-2xl dark:border-white/10 flex items-center justify-center p-8 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] group">
              {/* Subtle background glow/backdrop */}
              <div class="absolute inset-0 bg-linear-to-tr from-strategic/10 via-transparent to-transparent rounded-[2.5rem] pointer-events-none opacity-50 group-hover:opacity-100 transition-opacity duration-500" />

              <Image
                src={Logo}
                alt="Optim Logo"
                class="relative z-10 w-32 md:w-40 h-auto drop-shadow-md transition-transform duration-700 group-hover:scale-120"
                loading="eager"
              />
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>
