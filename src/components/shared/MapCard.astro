---
interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
}

const { dictionary } = Astro.props;
const mapQuery = encodeURIComponent(dictionary.contactPage.details.address);
---

<article class="glass-panel overflow-hidden rounded-[2rem] border border-line">
  <iframe
    title="Optim map"
    src={`https://www.google.com/maps?q=${mapQuery}&z=14&output=embed`}
    class="h-72 w-full border-0 grayscale"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
  <div class="p-6">
    <p class="text-xl font-semibold text-ink">{dictionary.contactPage.details.address}</p>
    <div class="mt-4 flex flex-wrap gap-3 text-sm text-muted">
      <a href={`mailto:${dictionary.contactPage.details.email}`}>{dictionary.contactPage.details.email}</a>
      <span class="h-1 w-1 self-center rounded-full bg-strategic"></span>
      <a href={`tel:${dictionary.contactPage.details.phone.replaceAll(" ", "")}`}>{dictionary.contactPage.details.phone}</a>
    </div>
    <a
      href={`https://www.google.com/maps/search/?api=1&query=${mapQuery}`}
      target="_blank"
      rel="noreferrer"
      class="mt-5 inline-flex rounded-full border border-line px-4 py-2 text-sm font-semibold text-ink transition-colors duration-300 hover:bg-panel"
    >
      {dictionary.contactPage.details.mapLabel}
    </a>
  </div>
</article>
