<button
  type="button"
  data-theme-toggle
  class="inline-flex items-center gap-2 rounded-full border border-line px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-ink transition-colors duration-300 hover:bg-panel"
  aria-label="Toggle color theme"
>
  <span class="inline-flex h-2 w-2 rounded-full bg-strategic"></span>
  <span data-theme-label>Dark</span>
</button>
