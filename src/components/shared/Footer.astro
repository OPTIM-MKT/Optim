---
import { localizePath, navigationSlugs, type Locale } from "@/lib/site";

interface Props {
  locale: Locale;
  dictionary: import("@/lib/site").SiteDictionary;
}

const { locale, dictionary } = Astro.props;

const labels = [
  dictionary.navigation.home,
  dictionary.navigation.about,
  dictionary.navigation.services,
  dictionary.navigation.pricing,
  dictionary.navigation.contact,
];
---

<footer class="border-t border-line bg-ink text-canvas">
  <div class="section-shell py-16">
    <div class="grid gap-12 md:grid-cols-[minmax(0,1.4fr)_repeat(3,minmax(0,0.8fr))]">
      <div class="space-y-5">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-canvas/72">Optim</p>
        <h2 class="max-w-md text-4xl font-semibold">{dictionary.footer.tagline}</h2>
        <p class="max-w-md text-base leading-7 text-canvas/72">{dictionary.footer.description}</p>
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-canvas/50">
          {dictionary.footer.navigationTitle}
        </p>
        <div class="mt-5 flex flex-col gap-3">
          {
            navigationSlugs.map((slug, index) => (
              <a href={localizePath(locale, slug)} class="text-base text-canvas/78 transition-colors duration-300 hover:text-canvas">
                {labels[index]}
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-canvas/50">
          {dictionary.footer.contactTitle}
        </p>
        <div class="mt-5 flex flex-col gap-3 text-base text-canvas/78">
          <a href={`mailto:${dictionary.contactPage.details.email}`}>{dictionary.contactPage.details.email}</a>
          <a href={`tel:${dictionary.contactPage.details.phone.replaceAll(" ", "")}`}>{dictionary.contactPage.details.phone}</a>
          <p>{dictionary.contactPage.details.address}</p>
        </div>
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-canvas/50">
          {dictionary.footer.socialTitle}
        </p>
        <div class="mt-5 flex flex-col gap-3">
          {
            dictionary.contactPage.socials.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noreferrer"
                class="text-base text-canvas/78 transition-colors duration-300 hover:text-canvas"
              >
                {social.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mt-12 border-t border-canvas/12 pt-6 text-sm text-canvas/52">
      {dictionary.footer.copyright}
    </div>
  </div>
</footer>
