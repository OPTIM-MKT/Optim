---
import Ramas from "./RamasComponent";

interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
}

const { dictionary } = Astro.props;
---

<section class="py-20">
  <div
    class="section-shell grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] overflow-hidden"
  >
    <article class="glass-panel rounded-4xl border border-line p-8 md:p-10">
      <p class="editorial-label">{dictionary.aboutPage.story.title}</p>
      <p class="mt-8 text-xl font-semibold leading-tight text-ink md:text-4xl">
        {dictionary.aboutPage.story.description}
      </p>
    </article>

    <!-- Ramas  -->
    <article
      class="rounded-4xl border border-line bg-ink p-8 text-canvas md:p-10"
    >
      <Ramas title={dictionary.aboutPage.branchesTitle} client:visible />
    </article>
  </div>
</section>
