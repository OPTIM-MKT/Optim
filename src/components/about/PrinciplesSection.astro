---
interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
}

const { dictionary } = Astro.props;
---

<section class="pb-24">
  <div class="section-shell">
    <h2 class="text-4xl font-semibold text-ink md:text-6xl">
      {dictionary.aboutPage.principles.title}
    </h2>
    <div class="mt-12 grid gap-4 md:grid-cols-3">
      {
        dictionary.aboutPage.principles.items.map((item) => (
          <article class="surface-card group p-6 transition-all duration-500 ease-in-out border-strategic shadow-2xl shadow-strategic/20 -translate-y-2 md:translate-y-0 md:border-ink/10 md:shadow-none md:hover:-translate-y-2 md:hover:border-strategic md:hover:shadow-2xl md:hover:shadow-strategic/20">
            <p class="text-2xl font-semibold transition-colors duration-300 text-strategic md:text-ink md:group-hover:text-strategic">
              {item.title}
            </p>

            <p class="mt-4 text-base leading-7">{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
