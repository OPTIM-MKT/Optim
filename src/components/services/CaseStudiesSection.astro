---
import { DEFAULT_MEDIA_IMAGE } from "@/lib/site";
import { Image } from "astro:assets";

interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
  empresas: import("astro:content").CollectionEntry<"empresas">[];
}

const { dictionary, empresas } = Astro.props;
---

<section class="pb-24">
  <div class="section-shell">
    <div class="max-w-3xl">
      <p class="editorial-label eyebrow-rule">
        {dictionary.home.companies.eyebrow}
      </p>
      <h2 class="mt-6 text-4xl font-semibold text-ink md:text-6xl">
        {dictionary.home.companies.title}
      </h2>
      <p class="mt-6 text-lg leading-8 text-muted">
        {dictionary.home.companies.description}
      </p>
    </div>

    <div
      class="mt-12 grid gap-6 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
    >
      {
        empresas.map((empresa) => {
          const isEn = empresa.id.startsWith("en/");
          const slug = empresa.id.replace(/^(es|en)\//, "");
          const href = isEn ? `/en/empresas/${slug}` : `/empresas/${slug}`;

          return (
            <a href={href} class="group block h-full">
              <article class="surface-card flex h-full flex-col rounded-4xl border border-line bg-panel p-4 transition-all duration-500 md:hover:-translate-y-2 md:hover:border-strategic md:hover:shadow-2xl md:hover:shadow-strategic/10">
                {/* Contenedor de Imagen Optimizado */}
                <div class="relative mb-6 aspect-4/5 w-full overflow-hidden rounded-3xl bg-ink/5">
                  <Image
                    src={empresa.data.featuredImage ?? DEFAULT_MEDIA_IMAGE}
                    alt={empresa.data.name}
                    class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                    loading="lazy"
                    transition:name={`hero-image-${empresa.id}`}
                  />

                  {/* Overlay sutil para mejorar legibilidad si fuera necesario */}
                  <div class="absolute inset-0 bg-linear-to-t from-ink/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
                </div>

                <div class="px-2 pb-4">
                  <h3
                    class="text-2xl font-bold text-ink transition-colors duration-300 group-hover:text-strategic"
                    transition:name={`title-${empresa.id}`}
                  >
                    {empresa.data.name}
                  </h3>

                  <div class="mt-2 inline-block text-[10px] font-bold uppercase tracking-[0.25em] text-strategic/80">
                    {empresa.data.industry}
                  </div>
                </div>
              </article>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
