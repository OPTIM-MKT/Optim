---
import { localizePath, type Locale } from "@/lib/site";
import { Button } from "@/components/ui/Button";
import { FiCalendar } from "react-icons/fi";

interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
  locale: Locale;
}

const { dictionary, locale } = Astro.props;
---

<section class="pb-24">
  <div class="section-shell">
    <article
      class="rounded-[2.5rem] border border-line bg-ink p-8 text-canvas md:p-12"
    >
      <p class="editorial-label !text-canvas/60">
        {dictionary.servicesPage.method.title}
      </p>
      <div class="mt-10 grid gap-4 md:grid-cols-5">
        {
          dictionary.servicesPage.method.items.map((item, index) => (
            <div class="rounded-3xl border transition-all duration-500 group -translate-y-2 border-strategic md:translate-y-0 md:border-canvas/12 p-5 md:hover:-translate-y-2 md:hover:border-strategic">
              <p class="text-sm uppercase tracking-[0.22em] transition-colors duration-300 text-strategic md:text-canvas/50 md:group-hover:text-strategic">
                0{index + 1}
              </p>

              <p class="mt-5 text-base leading-7 transition-colors duration-300 text-strategic md:text-canvas/76 md:group-hover:text-strategic">
                {item}
              </p>
            </div>
          ))
        }
      </div>

      <Button
        variant="black&white"
        href={localizePath(locale, "contact")}
        className="mt-10 animate-bounce animate-duration-1000 hover:border-white dark:hover:border-black animate-ease-in-out"
      >
        <span class="shrink-0 text-lg"><FiCalendar /></span>
        {dictionary.navigation.cta}
      </Button>
    </article>
  </div>
</section>
