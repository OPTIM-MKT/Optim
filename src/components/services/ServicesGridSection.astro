---
import ScrollCarousel from "@/components/shared/ScrollCarousel";
import ScrollReveal from "@/components/shared/ScrollReveal";
import { localizePath, type Locale } from "@/lib/site";

interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
  locale: Locale;
}

const { dictionary, locale } = Astro.props;
const contactHref = localizePath(locale, "contact");
---

<section class="relative pt-12">
  <div class="section-shell">
    <ScrollReveal client:visible duration={0.8}>
      <div class="max-w-3xl">
        <p class="editorial-label eyebrow-rule">
          {dictionary.servicesPage.intro.title}
        </p>
        <p class="mt-6 text-lg leading-8">
          {dictionary.servicesPage.intro.description}
        </p>
      </div>
    </ScrollReveal>
  </div>

  <div class="mt-16 w-full">
    <ScrollCarousel
      client:load
      items={dictionary.servicesPage.services}
      ariaLabel={dictionary.servicesPage.intro.title}
      contactHref={contactHref}
      contactLabel={dictionary.navigation.cta}
    />
  </div>
</section>
