---
import SwiperCarousel from "@/components/SwiperCarousel";

interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
}

const { dictionary } = Astro.props;
---

<section class="pb-20">
  <div class="section-shell">
    <div class="max-w-3xl">
      <p class="editorial-label eyebrow-rule">{dictionary.servicesPage.intro.title}</p>
      <p class="mt-6 text-lg leading-8">{dictionary.servicesPage.intro.description}</p>
    </div>

    <div class="mt-12">
      <SwiperCarousel client:visible variant="servicesPage" items={dictionary.servicesPage.services} ariaLabel={dictionary.servicesPage.intro.title} />
    </div>
  </div>
</section>
