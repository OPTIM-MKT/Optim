---
interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
}

const { dictionary } = Astro.props;
---

<section class="snap-section flex items-center">
  <div class="section-shell py-20">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-white/60">{dictionary.home.process.eyebrow}</p>
      <h2 class="mt-6 text-4xl font-semibold text-white md:text-6xl">{dictionary.home.process.title}</h2>
    </div>
    <div class="mt-12 grid gap-4 md:grid-cols-5">
      {
        dictionary.home.process.steps.map((step, index) => (
          <article class="rounded-[1.75rem] border border-white/10 bg-white/5 backdrop-blur-sm p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-strategic">0{index + 1}</p>
            <h3 class="mt-8 text-2xl font-semibold text-white">{step.title}</h3>
            <p class="mt-4 text-sm leading-7 text-white/70">{step.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
