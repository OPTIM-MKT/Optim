---
import OptimServices from "./OptimServices.astro";
import { getCollection } from "astro:content";

interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
  locale: import("@/lib/site").Locale;
}

const { dictionary, locale } = Astro.props;
const allUnits = await getCollection("optim");
const units = allUnits.filter((unit) => {
  if (locale === "en") return unit.id.startsWith("en/");
  return !unit.id.startsWith("en/");
});
---

<section class="snap-section flex items-center">
  <div class="section-shell py-20">
    <div class="max-w-3xl">
      <p class="editorial-label eyebrow-rule">
        {dictionary.home.branches.eyebrow}
      </p>
      <h2
        class="mt-6 text-4xl font-semibold text-ink dark:text-white md:text-6xl"
      >
        {dictionary.home.branches.title}
      </h2>
    </div>

    <section class="mt-10">
      <OptimServices units={units} />
    </section>
  </div>
</section>
