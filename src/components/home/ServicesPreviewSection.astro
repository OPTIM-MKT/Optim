---
import { localizePath, type Locale } from "@/lib/site";
import { Button } from "@/components/ui/Button";
import { FiCalendar, FiGrid } from "react-icons/fi";
import { Icon } from "astro-icon/components";

interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
  locale: Locale;
}

const { dictionary, locale } = Astro.props;

const serviceIcons = [
  "fa6-solid/bullseye",
  "fa6-solid/pen-nib",
  "fa6-solid/magnifying-glass-chart",
  "fa6-solid/fingerprint",
  "fa6-solid/laptop-code",
  "fa6-solid/users-gear",
];
---

<section class="snap-section flex items-center">
  <div class="section-shell py-20">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
      <div class="space-y-6">
        <p class="editorial-label eyebrow-rule">
          {dictionary.home.servicesPreview.eyebrow}
        </p>
        <h2 class="max-w-4xl text-4xl font-semibold text-ink md:text-6xl">
          {dictionary.home.hero.headline}
          <span class="block text-strategic"
            >{dictionary.home.hero.headlineAccent}</span
          >
        </h2>
      </div>

      <div class="space-y-6">
        <p class="max-w-2xl text-lg leading-8">
          {dictionary.home.hero.subheadline}
        </p>
        <div class="flex flex-wrap gap-4">
          <Button variant="primary" href={localizePath(locale, "contact")}>
            <span class="shrink-0 text-lg"><FiCalendar /></span>
            {dictionary.home.hero.ctaPrimary}
          </Button>
          <Button variant="simple" href={localizePath(locale, "services")}>
            <span class="shrink-0 text-lg"><FiGrid /></span>
            {dictionary.home.hero.ctaSecondary}
          </Button>
        </div>
      </div>
    </div>

    <!-- 6 cards -->
    <div class="mt-16 grid gap-4 grid-cols-2 md:grid-cols-2 xl:grid-cols-3">
      {
        dictionary.home.servicesPreview.items.map((service, index) => {
          const iconName = serviceIcons[index % serviceIcons.length];
          return (
            <article class="surface-card group relative overflow-hidden p-6 transition-all duration-500 border-strategic shadow-2xl shadow-strategic/20 cursor-pointer min-h-[180px] flex items-end md:translate-y-0 md:hover:-translate-y-2 md:hover:border-strategic md:hover:shadow-2xl">
              <a
                href={localizePath(locale, "services")}
                class="absolute inset-0 flex flex-col justify-between p-6 focus:outline-none"
              >
                <div class="flex justify-between items-start">
                  <span class="text-xs font-bold tracking-widest text-strategic/50 md:text-ink/30 md:group-hover:text-strategic/50 transition-colors duration-300">
                    0{index + 1}
                  </span>

                  {/* Icono superior */}
                  <div class="text-2xl text-strategic opacity-100 translate-y-0 transition-all duration-500 ease-out md:opacity-0 md:-translate-y-4 md:group-hover:opacity-100 md:group-hover:translate-y-0">
                    <Icon name={iconName} />
                  </div>
                </div>

                <div class="relative z-10">
                  <span class="text-lg md:text-2xl font-semibold text-strategic transition-colors duration-300 md:text-ink md:group-hover:text-strategic">
                    {service}
                  </span>
                  {/* underline */}
                  <div class="h-0.5 bg-strategic mt-2 transition-all duration-500 w-full md:w-0 md:group-hover:w-full" />
                </div>

                {/* Icono grande de fondo */}
                <div class="absolute bottom-0 right-0 text-9xl text-strategic opacity-[0.07] translate-y-0 rotate-0 transition-all duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] pointer-events-none md:-bottom-6 md:-right-6 md:opacity-0 md:translate-y-10 md:rotate-12 md:group-hover:opacity-[0.07] md:group-hover:translate-y-0 md:group-hover:rotate-0">
                  <Icon name={iconName} />
                </div>

                {/* Efecto de brillo/glow */}
                <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-strategic/10 rounded-full blur-3xl transition-all duration-700 pointer-events-none md:bg-strategic/0 md:group-hover:bg-strategic/10" />
              </a>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
