---
import SwiperCarousel from "@/components/SwiperCarousel";
import type { SiteDictionary } from "@/lib/site";

interface Props {
  dictionary: SiteDictionary;
}

const { dictionary } = Astro.props;
const t = dictionary.home.testimonials;
---

<section class="snap-section flex flex-col justify-center py-20 min-h-[70vh]">
  <div class="section-shell">
    <p class="editorial-label eyebrow-rule">{t.eyebrow}</p>
    <h2 class="mt-6 max-w-3xl text-4xl font-semibold text-ink md:text-6xl">
      {t.title}
    </h2>
  </div>

  <div class="mt-12 w-full overflow-hidden">
    <SwiperCarousel
      client:visible
      variant="testimonials"
      items={t.items}
      ariaLabel={t.ariaLabel}
    />
  </div>
</section>
