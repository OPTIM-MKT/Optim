---
interface Props {
  dictionary: import("@/lib/site").SiteDictionary;
}

const { dictionary } = Astro.props;
---

<section class="snap-section flex items-center">
  <div class="section-shell py-20">
    <div class="max-w-3xl">
      <p class="editorial-label eyebrow-rule">
        {dictionary.home.branches.eyebrow}
      </p>
      <h2
        class="mt-6 text-4xl font-semibold text-ink dark:text-white md:text-6xl"
      >
        {dictionary.home.branches.title}
      </h2>
    </div>
    <div class="mt-12 grid gap-4 lg:grid-cols-2">
      {
        dictionary.home.branches.items.map((branch) => (
          <article class="rounded-[2rem] border border-line bg-ink px-8 py-10 text-canvas">
            <p class="text-3xl font-semibold md:text-4xl dark:text-black text-white">
              {branch.name}
            </p>
            <p class="mt-6 max-w-2xl text-base leading-7 text-canvas/72">
              {branch.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
