---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="snap-section flex items-center">
  <div class="section-shell py-24">
    <div class="max-w-5xl">
      <p class="editorial-label eyebrow-rule">{eyebrow}</p>
      <h1 class="mt-6 text-5xl font-semibold text-ink md:text-7xl lg:text-[6.5rem]">
        {title}
      </h1>
      <p class="mt-8 max-w-3xl text-lg leading-8 md:text-xl">{description}</p>
    </div>
  </div>
</section>
