---
import { localizePath, navigationSlugs, normalizePath, switchLocalePath, type Locale } from "@/lib/site";

interface Props {
  locale: Locale;
  dictionary: import("@/lib/site").SiteDictionary;
  currentPath: string;
}

const { locale, dictionary, currentPath } = Astro.props;

const labels = [
  dictionary.navigation.home,
  dictionary.navigation.about,
  dictionary.navigation.services,
  dictionary.navigation.pricing,
  dictionary.navigation.contact,
];

const normalizedCurrentPath = normalizePath(currentPath);
const alternateLocale: Locale = locale === "es" ? "en" : "es";
const alternatePath = switchLocalePath(currentPath, alternateLocale);
---

<header class="sticky top-0 z-50 border-b border-line bg-canvas/85 backdrop-blur-xl">
  <div class="section-shell !py-4">
    <div class="flex items-center justify-between gap-6">
      <a href={localizePath(locale)} class="flex items-center gap-3 text-sm font-semibold uppercase tracking-[0.24em] text-ink">
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-ink text-canvas">O</span>
        <span>Optim</span>
      </a>

      <nav class="hidden items-center gap-6 lg:flex">
        {
          navigationSlugs.map((slug, index) => {
            const href = localizePath(locale, slug);
            const isActive =
              normalizedCurrentPath === href ||
              (slug === "" && normalizedCurrentPath === localizePath(locale));

            return (
              <a
                href={href}
                class:list={[
                  "text-sm font-medium transition-colors duration-300",
                  isActive ? "text-strategic" : "text-muted hover:text-ink",
                ]}
              >
                {labels[index]}
              </a>
            );
          })
        }
      </nav>

      <div class="flex items-center gap-3">
        <a
          href={alternatePath}
          class="rounded-full border border-line px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-ink transition-colors duration-300 hover:bg-panel"
          aria-label={locale === "es" ? "Switch to English" : "Cambiar a español"}
        >
          {alternateLocale.toUpperCase()}
        </a>
        <a
          href={localizePath(locale, "contact")}
          class="rounded-full bg-ink px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.2em] text-canvas transition-transform duration-300 hover:-translate-y-0.5"
        >
          {dictionary.navigation.cta}
        </a>
      </div>
    </div>
  </div>
</header>
