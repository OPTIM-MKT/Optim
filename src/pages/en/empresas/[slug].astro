---
import ContentLayout from "@/layouts/ContentLayout.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
export const prerender = true;

export async function getStaticPaths() {
  const empresas = await getCollection("empresas");
  // Only build paths for English entries
  const enEmpresas = empresas.filter((emp) => emp.id.startsWith("en/"));
  return enEmpresas.map((empresa) => ({
    params: { slug: empresa.id.replace(/^en\//, "") },
    props: { empresa },
  }));
}

const { empresa } = Astro.props;
const { Content } = await render(empresa);
const locale = "en";
---

<ContentLayout
  locale={locale}
  title={empresa.data.name}
  description={empresa.data.description || empresa.data.industry}
>
  <div class="section-shell py-12 md:py-20 min-h-screen">
    {/* Hero Section */}
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-start mb-24">
      {/* Left Column: Image Card */}
      <div class="flex flex-col gap-4">
        <div
          class="media-frame relative aspect-4/3 w-full overflow-hidden bg-panel rounded-3xl border border-line"
        >
          <Image
            src={empresa.data.featuredImage}
            alt={empresa.data.name}
            class="h-full w-full object-cover"
            transition:name={`hero-image-${empresa.id}`}
          />
          {/* Floating Badge */}
          <div class="absolute left-6 top-6">
            <span
              class="rounded-full border border-white/20 bg-black/40 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-white backdrop-blur-md"
            >
              {empresa.data.industry}
            </span>
          </div>
        </div>
      </div>

      {/* Right Column: Key Information */}
      <div class="flex flex-col justify-center space-y-8 lg:pt-8">
        <div>
          <span class="editorial-label text-strategic block mb-4"
            >Case Study</span
          >
          <h1
            class="text-4xl font-semibold leading-tight text-ink md:text-5xl border-l-[3px] border-strategic pl-6 ml-[-1.65rem]"
            style={`view-transition-name: title-${empresa.id}`}
          >
            {empresa.data.name}
          </h1>
        </div>

        {
          empresa.data.description && (
            <p class="text-lg leading-relaxed text-muted">
              {empresa.data.description}
            </p>
          )
        }

        {/* Services / Keywords Tag list */}
        {
          empresa.data.servicesProvided &&
            empresa.data.servicesProvided.length > 0 && (
              <div class="border-t border-line mt-8 pt-8">
                <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-ink mb-4">
                  Implemented Services
                </h3>
                <div class="flex flex-wrap gap-2">
                  {empresa.data.servicesProvided.map((service) => (
                    <span class="rounded-full border border-line bg-panel px-4 py-2 text-xs font-medium text-ink transition-colors hover:border-strategic">
                      {service}
                    </span>
                  ))}
                </div>
              </div>
            )
        }

        {/* Links / External URLs Tag list */}
        {
          empresa.data.links && empresa.data.links.length > 0 && (
            <div class="border-t border-line mt-8 pt-8">
              <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-ink mb-4">
                Project Links
              </h3>
              <div class="flex flex-wrap gap-3">
                {empresa.data.links.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-center gap-2 rounded-full border border-line bg-canvas px-4 py-2 text-xs font-semibold uppercase tracking-widest text-ink transition-colors hover:border-strategic hover:bg-strategic/5"
                  >
                    {link.label}
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      class="opacity-50 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-strategic group-hover:opacity-100"
                    >
                      <path
                        d="M7 17l9.2-9.2M17 17V7H7"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>

    {/* Section: Main Markdown Content */}
    <div
      class="prose prose-lg dark:prose-invert max-w-3xl mx-auto prose-headings:font-display prose-headings:font-semibold prose-a:text-strategic prose-p:text-muted prose-h2:text-ink prose-h3:text-ink prose-strong:text-ink pb-20"
    >
      <Content />
    </div>
  </div>
</ContentLayout>
