---
import ContentLayout from "@/layouts/ContentLayout.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import { FiArrowUpRight, FiCheckCircle } from "react-icons/fi";
import ClosingSection from "@/components/home/ClosingSection.astro";

import { getDictionary } from "@/lib/site";

const dictionary = getDictionary("es");

export const prerender = true;

export async function getStaticPaths() {
  const empresas = await getCollection("empresas");
  const esEmpresas = empresas.filter((emp) => !emp.id.startsWith("en/"));
  return esEmpresas.map((empresa) => ({
    params: { slug: empresa.id.replace(/^es\//, "") },
    props: { empresa },
  }));
}

const { empresa } = Astro.props;
const { Content } = await render(empresa);
const locale = "es";
---

<ContentLayout
  locale={locale}
  title={empresa.data.name}
  description={empresa.data.description || empresa.data.industry}
>
  <div class="section-shell py-12">
    {/* --- HERO SPLIT SECTION --- */}
    <div
      class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-20 items-stretch mb-32"
    >
      {/* Left: The Transition Key (Image) */}
      <div class="relative group">
        <div
          class="media-frame sticky top-32 aspect-4/3 w-full overflow-hidden rounded-[2.5rem] border border-line bg-panel shadow-2xl shadow-strategic/5"
        >
          <Image
            src={empresa.data.featuredImage}
            alt={empresa.data.name}
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            transition:name={`hero-image-${empresa.id.replace(/\//g, "-")}`}
          />
          {/* Industry Badge Over Image */}
          <div class="absolute bottom-8 left-8">
            <span
              class="rounded-full border border-white/20 bg-black/60 px-5 py-2 text-xs font-bold uppercase tracking-[0.2em] text-white backdrop-blur-xl"
            >
              {empresa.data.industry}
            </span>
          </div>
        </div>
      </div>

      {/* Right: Project Header Info */}
      <div class="flex flex-col justify-center">
        <div class="space-y-8">
          <header>
            <span
              class="editorial-label text-strategic block mb-6 tracking-[0.3em]"
              >Caso de Estudio</span
            >
            <h1
              class="text-5xl font-bold leading-[1.1] text-ink md:text-7xl"
              transition:name={`title-${empresa.id.replace(/\//g, "-")}`}
            >
              {empresa.data.name}
            </h1>
          </header>

          <p class="text-xl leading-relaxed text-muted max-w-xl">
            {empresa.data.description}
          </p>

          {/* Key Metrics / Results Preview */}
          {
            empresa.data.results && (
              <div class="p-6 rounded-3xl bg-strategic/5 border border-strategic/10 flex items-start gap-4">
                <FiCheckCircle className="text-strategic text-2xl shrink-0 mt-1" />
                <p class="text-ink font-medium leading-relaxed italic">
                  "{empresa.data.results}"
                </p>
              </div>
            )
          }

          {/* Quick Links */}
          {
            empresa.data.links && (
              <div class="flex flex-wrap gap-4 pt-4">
                {empresa.data.links.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    class="group flex items-center gap-3 rounded-full bg-ink px-8 py-4 text-xs font-bold uppercase tracking-widest text-canvas transition-all hover:bg-strategic active:scale-95"
                  >
                    {link.label}
                    <FiArrowUpRight className="text-lg transition-transform group-hover:translate-x-1 group-hover:-translate-y-1" />
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>
    </div>

    {/* --- DETAILED CONTENT SECTION --- */}
    <div
      class="grid lg:grid-cols-[1fr_350px] gap-20 border-t border-line pt-20"
    >
      {/* The Styled Markdown Content */}
      <div
        class="prose prose-lg dark:prose-invert max-w-none
        prose-headings:text-ink prose-headings:font-bold prose-headings:tracking-tight
        prose-p:text-muted prose-p:leading-8
        prose-strong:text-ink prose-strong:font-bold
        prose-li:text-muted
        prose-img:rounded-[2rem] prose-img:shadow-xl
        prose-blockquote:border-l-strategic prose-blockquote:bg-strategic/5 prose-blockquote:py-2 prose-blockquote:px-8 prose-blockquote:rounded-r-2xl prose-blockquote:italic prose-blockquote:text-ink
        prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-8
        prose-hr:border-line"
      >
        <Content />
      </div>

      {/* Sidebar: Complementary Info */}
      <aside class="space-y-12">
        {
          empresa.data.servicesProvided && (
            <div class="p-8 rounded-4xl border border-line bg-panel/50 backdrop-blur-sm">
              <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-ink/40 mb-8">
                Servicios Implementados
              </h3>
              <ul class="space-y-4">
                {empresa.data.servicesProvided.map((service) => (
                  <li class="flex items-center gap-3 text-sm font-semibold text-ink">
                    <div class="h-1.5 w-1.5 rounded-full bg-strategic" />
                    {service}
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </aside>
    </div>
  </div>
  <ClosingSection dictionary={dictionary} locale={locale} isSnap={false} />
</ContentLayout>
